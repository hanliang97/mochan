/* secrets.h —— WiFi 凭证和地理坐标的本地配置
 *
 * 用法：
 *   cp src/secrets.h.example src/secrets.h
 *   然后把下面的值改成你自己的
 *
 * src/secrets.h 已在 .gitignore 里，不会被提交，避免泄露真实密码。
 * 如果不配置也能编译，但 WiFi 会连不上、天气功能不可用。
 */
#ifndef _SECRETS_H
#define _SECRETS_H

#define WIFI_SSID  "你的WiFi名"
#define WIFI_PASS  "你的WiFi密码"

// 天气请求用的经纬度，默认广州
#define LAT  23.13
#define LON  113.26

#endif
